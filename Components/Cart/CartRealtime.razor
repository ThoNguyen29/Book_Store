<div class="cart-container js-cart-page">
    <div class="cart-title">Giỏ hàng của bạn</div>

    @if (!_items.Any())
    {
        <div class="cart-empty">
            Giỏ hàng đang trống
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle cart-table text-center">
                <thead class="table-light">
                    <tr>
                        <th>Hình</th>
                        <th class="text-start">Tên sách</th>
                        <th>Giá</th>
                        <th>Số lượng</th>
                        <th>Tạm tính</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _items)
                    {
                        var lineTotal = item.Price * item.Quantity;
                        <tr @key="item.ProductId"
                            data-product-id="@item.ProductId"
                            data-unit-price="@item.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                            <td>
                                <img class="cart-item-image" src="@item.Image" alt="@item.ProductName" onerror="this.src='/images/no-image.png'" />
                            </td>
                            <td class="text-start fw-semibold">@item.ProductName</td>
                            <td>@item.Price.ToString("N0") ₫</td>
                            <td>
                                <div class="cart-qty-group">
                                    <form method="post" action="/Cart/DecreaseQuantity" class="cart-action-form">
                                        <input type="hidden" name="id" value="@item.ProductId" />
                                        <button type="submit"
                                                class="cart-qty-btn js-cart-decrease"
                                                data-product-id="@item.ProductId"
                                                @onclick="() => Decrease(item.ProductId)"
                                                @onclick:preventDefault="true">
                                            <i class="fas fa-minus"></i>
                                        </button>
                                    </form>

                                    <input class="cart-qty-input"
                                           type="number"
                                           min="1"
                                           value="@item.Quantity"
                                           data-product-id="@item.ProductId"
                                           @onchange="e => HandleQuantityInput(e, item.ProductId)" />

                                    <form method="post" action="/Cart/IncreaseQuantity" class="cart-action-form">
                                        <input type="hidden" name="id" value="@item.ProductId" />
                                        <button type="submit"
                                                class="cart-qty-btn js-cart-increase"
                                                data-product-id="@item.ProductId"
                                                @onclick="() => Increase(item.ProductId)"
                                                @onclick:preventDefault="true">
                                            <i class="fas fa-plus"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                            <td class="fw-bold text-danger js-cart-line-total">@lineTotal.ToString("N0") ₫</td>
                            <td>
                                <form method="post" action="/Cart/RemoveItemForm" class="cart-remove-form">
                                    <input type="hidden" name="id" value="@item.ProductId" />
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger js-cart-remove"
                                            data-product-id="@item.ProductId"
                                            @onclick="() => Remove(item.ProductId)"
                                            @onclick:preventDefault="true">
                                        Xóa
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="total-section">
            Tổng cộng: <span id="cartPageTotal">@Total.ToString("N0") ₫</span>
        </div>

        <a href="/Cart/Checkout" class="btn btn-success checkout-btn">Thanh toán ngay</a>
    }
</div>
