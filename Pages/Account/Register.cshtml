@page "/Account/Register"
@model Book_Store.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/register.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>

<body>
    <div class="auth-wrapper">
        <div class="container">
            <div class="row auth-card justify-content-center">
                <div class="col-md-6 px-0 d-none d-md-block">
                    <div class="auth-image-section h-100">
                        <img src="~/images/dangnhap1.jpg" alt="Đăng ký">
                    </div>
                </div>

                <div class="col-md-6 p-5">
                    <h2 class="mb-4 text-center">Đăng ký tài khoản</h2>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
                    }

                    <form method="post">
                        @Html.AntiForgeryToken()

                        <div class="form-group mb-3">
                            <label asp-for="Input.Email" class="form-label">Email:</label>
                            <input asp-for="Input.Email" type="email" class="form-control"
                                   placeholder="example@gmail.com" required />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Input.FullName" class="form-label">Họ và tên:</label>
                            <input asp-for="Input.FullName" type="text" class="form-control"
                                   placeholder="Nhập họ và tên" />
                            <span asp-validation-for="Input.FullName" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Input.Password" class="form-label">Mật khẩu:</label>
                            <input asp-for="Input.Password" type="password" class="form-control" required />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Input.ConfirmPassword" class="form-label">Xác nhận mật khẩu:</label>
                            <input asp-for="Input.ConfirmPassword" type="password" class="form-control" required />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">Đăng ký</button>
                        </div>

                        <p class="text-center mt-3">
                            Đã có tài khoản? <a asp-page="/Account/Login">Đăng nhập ngay</a>
                        </p>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>

</html>
