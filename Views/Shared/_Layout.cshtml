﻿@using Book_Store.Models
@using Microsoft.EntityFrameworkCore
@inject Book_Store.Models.ApplicationDbContext _layoutDb
<!DOCTYPE html>
<html lang="en">

<head>
    @* CSS *@
    @* HeaderCSS *@
    <link rel="stylesheet" href="~/css/header.css" asp-append-version="true" />
    @* CategoriesCSS *@
    <link rel="stylesheet" href="~/css/categories.css" asp-append-version="true" />
    @* --- *@
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />
    <title>@ViewData["Title"] - Book_Store</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style_layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/book-card.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/checkout.css" asp-append-version="true" />
</head>

<body>
    <div class="sticky-top-bar">
        <header class="site-header">
            <div class="container header-main">
        
                <a href="/" class="logo-wrapper">
                    <img src="~/images/logo.png" alt="Nhà Sách Hải An" class="logo-img">
                </a>

                <div class="search-wrapper">
                    <form action="/Search" method="get" class="search-box">
                        <input type="text" name="q" placeholder="Bạn muốn tìm sách gì?">
                        <button type="submit">
                            <i class="fas fa-search"></i>
                        </button>
                    </form>
                </div>

                <div class="actions-wrapper">
            
                    <div class="auth-section">
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <div class="dropdown">
                                <a href="#" class="user-name dropdown-toggle" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle"></i> @User.Identity?.Name
                                </a>
                                <ul class="dropdown-menu">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">Quản trị</a></li>
                                    }
                                    <li><a class="dropdown-item" href="/Order/History">Đơn hàng</a></li>
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger">Đăng xuất</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <div class="guest-links">
                                <a asp-page="/Account/Login">Đăng nhập</a>
                                <span class="divider">|</span>
                                <a asp-page="/Account/Register">Đăng ký</a>
                            </div>
                        }
                    </div>

                    @await Component.InvokeAsync("MiniCart")

                </div>
            </div>
        </header>

        <nav class="nav-main">
            <div class="container nav-container">
        
                <div class="category-wrapper">
                    <div class="category-menu" onclick="toggleCategoryDropdown(event)">
                        <i class="fas fa-bars"></i>
                        <span>DANH MỤC SẢN PHẨM</span>
                    </div>

                    <div class="category-dropdown" id="categoryDropdown">
                        <ul class="category-list">
                            @{
                                var navCategories = await _layoutDb.Categories
                                    .AsNoTracking()
                                    .OrderBy(c => c.Name)
                                    .ToListAsync();
                            }
                            @foreach (var cat in navCategories)
                            {
                                <li>
                                    <a href="/Home/ProductList?categoryId=@cat.CategoryID">@cat.Name</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>

                <div class="main-nav-links">
                    <a href="/" class="nav-link">Trang chủ</a>
                    <a asp-controller="Home" asp-action="ProductList" class="nav-link">Cửa hàng</a>
                    <a asp-page="/About" class="nav-link">Giới thiệu</a>
                </div>
            </div>
        </nav>
    </div><!-- /.sticky-top-bar -->

               


    <main role="main" class="pb-3">
        @RenderBody()
    </main>


    @* <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Book_Store - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer> *@
    <!-- Footer -->
    <footer>
        <div class="footer-content">
            <div class="footer-section">
                <h3>Về chúng tôi</h3>
                <p>Nhà Sách \ - Nơi hội tụ tri thức, nơi lan tỏa đam mê đọc sách.</p>
                <div class="social-links">
                    <a href="#"><i class="fab fa-facebook-f"></i></a>
                    <a href="#"><i class="fab fa-youtube"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-tiktok"></i></a>
                </div>
            </div>

            <div class="footer-section">
                <h3>Hỗ trợ khách hàng</h3>
                <ul>
                    <li><a href="#">Chính sách đổi trả</a></li>
                    <li><a href="#">Chính sách bảo mật</a></li>
                    <li><a href="#">Phương thức thanh toán</a></li>
                    <li><a href="#">Hướng dẫn mua hàng</a></li>
                </ul>
            </div>

            <div class="footer-section">
                <h3>Danh mục sản phẩm</h3>
                <ul>
                    <li><a href="#">Sách kinh doanh</a></li>
                    <li><a href="#">Sách thiếu nhi</a></li>
                    <li><a href="#">Sách kỹ năng</a></li>
                    <li><a href="#">Văn học - Tiểu thuyết</a></li>
                </ul>
            </div>

            <div class="footer-section">
                <h3>Liên hệ</h3>
                <ul>
                    <li><i class="fas fa-map-marker-alt"></i> 123 Đường ABC, Q1, TP.HCM</li>
                    <li><i class="fas fa-phone"></i> 1900 xxxx</li>
                    <li><i class="fas fa-envelope"></i> contact@nhasach.com</li>
                    <li><i class="fas fa-clock"></i> 8:00 - 22:00 (Hàng ngày)</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="store-chat-widget">
        <button type="button"
                class="store-chat-toggle"
                id="storeChatToggle"
                onclick="toggleStoreChatWidget(event)"
                aria-expanded="false"
                aria-controls="storeChatPanel"
                aria-label="Mo tro ly nha sach">
            <i class="fas fa-comments"></i>
        </button>

        <section class="store-chat-panel"
                 id="storeChatPanel"
                 aria-hidden="true"
                 aria-label="Tro ly nha sach AI">
            <div class="store-chat-panel__header">
                <div>
                    <p class="store-chat-panel__eyebrow">Tro ly AI</p>
                    <h3>Ho tro tim sach nhanh</h3>
                </div>
                <button type="button" class="store-chat-close" id="storeChatClose" onclick="toggleStoreChatWidget(event)" aria-label="Dong tro ly">
                    <span class="visually-hidden">Dong tro ly</span>
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="store-chat-body" id="storeChatBody">
                <div class="store-chat-message bot">
                    <div class="store-chat-avatar">
                        <i class="fas fa-book-open"></i>
                    </div>
                    <div class="store-chat-bubble">
                        Chao ban, minh co the giup tim sach, goi y theo the loai, tac gia hoac muc gia phu hop.
                    </div>
                </div>
            </div>

            <form class="store-chat-form" id="storeChatForm">
                <input type="text"
                       id="storeChatInput"
                       class="store-chat-input"
                       placeholder="Hoi ve sach, the loai, tac gia..."
                       autocomplete="off" />
                <button type="submit" class="store-chat-send" id="storeChatSend" aria-label="Gui cau hoi">
                    <i class="fas fa-arrow-up"></i>
                </button>
            </form>
        </section>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/book-card.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>

