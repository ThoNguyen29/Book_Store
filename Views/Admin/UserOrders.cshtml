@model Book_Store.ViewModel.Admin.AdminUserOrdersViewModel

@{
    Layout = "~/Views/Shared/_Admin_Layout.cshtml";
    ViewData["Title"] = "Don hang cua khach hang";
    var fullName = Model?.FullName ?? "-";
    var email = Model?.Email ?? "-";
    var orders = (IReadOnlyList<Book_Store.ViewModel.Admin.AdminOrderSummaryItemViewModel>?)Model?.Orders
        ?? Array.Empty<Book_Store.ViewModel.Admin.AdminOrderSummaryItemViewModel>();
}

<div class="mb-3">
    <a asp-action="UserManagement" class="btn btn-outline-secondary btn-sm">Quay lai quan ly nguoi dung</a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <h4 class="card-title mb-1">@fullName</h4>
        <p class="text-muted mb-0">@email</p>
    </div>
</div>

@if (!orders.Any())
{
    <div class="alert alert-info">Khach hang nay chua co don hang.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle bg-white">
            <thead class="table-light">
                <tr>
                    <th>Ma don</th>
                    <th>Ten khach hang</th>
                    <th>Ngay dat</th>
                    <th>So luong sach</th>
                    <th>Tong tien</th>
                    <th>Trang thai</th>
                    <th class="text-center">Thao tac</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in orders)
                {
                    <tr>
                        <td>#@order.OrderId</td>
                        <td>@order.CustomerName</td>
                        <td>
                            <date-time value="@order.OrderDate"></date-time>
                        </td>
                        <td>@order.ItemCount</td>
                        <td>
                            <money value="@order.TotalAmount" currency="d"></money>
                        </td>
                        <td>
                            <order-status-badge status="@order.Status"></order-status-badge>
                        </td>
                        <td class="text-center">
                            <a asp-action="OrderDetails"
                               asp-route-id="@order.OrderId"
                               class="btn btn-sm btn-primary">
                                Chi tiet don hang
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
