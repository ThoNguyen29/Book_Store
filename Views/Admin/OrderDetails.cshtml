@model Book_Store.ViewModel.Admin.AdminOrderDetailsViewModel

@{
    Layout = "~/Views/Shared/_Admin_Layout.cshtml";
    ViewData["Title"] = "Chi tiet don hang";
    var vm = Model ?? new Book_Store.ViewModel.Admin.AdminOrderDetailsViewModel();
    var statusSuccess = TempData["OrderStatusSuccess"] as string;
    var statusError = TempData["OrderStatusError"] as string;

    string GetStatusLabel(Book_Store.Models.OrderStatus status)
    {
        return status switch
        {
            Book_Store.Models.OrderStatus.Pending => "Cho xac nhan",
            Book_Store.Models.OrderStatus.Confirmed => "Da xac nhan",
            Book_Store.Models.OrderStatus.Shipping => "Dang giao",
            Book_Store.Models.OrderStatus.Completed => "Hoan thanh",
            Book_Store.Models.OrderStatus.Cancelled => "Da huy",
            _ => status.ToString()
        };
    }
}

<div class="mb-3 d-flex gap-2">
    <a asp-action="UserManagement" class="btn btn-outline-secondary btn-sm">Danh sach nguoi dung</a>
    @if (vm.UserId.HasValue)
    {
        <a asp-action="UserOrders" asp-route-id="@vm.UserId.Value" class="btn btn-outline-primary btn-sm">
            Danh sach don cua khach
        </a>
    }
</div>

@if (!string.IsNullOrWhiteSpace(statusSuccess))
{
    <div class="alert alert-success">@statusSuccess</div>
}

@if (!string.IsNullOrWhiteSpace(statusError))
{
    <div class="alert alert-danger">@statusError</div>
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white">
        <h4 class="mb-0">Chi tiet don hang #@vm.OrderId</h4>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <div><strong>Ten khach hang:</strong> @vm.CustomerName</div>
                <div><strong>Email:</strong> @vm.CustomerEmail</div>
                <div><strong>Dia chi giao hang:</strong> @vm.ShippingAddress</div>
            </div>
            <div class="col-md-6">
                <div>
                    <strong>Ngay dat:</strong>
                    <date-time value="@vm.OrderDate"></date-time>
                </div>
                <div><strong>Phuong thuc thanh toan:</strong> @vm.PaymentMethod</div>
                <div>
                    <strong>Trang thai:</strong>
                    <order-status-badge status="@vm.Status"></order-status-badge>
                </div>
                <div>
                    <strong>Tong tien:</strong>
                    <money value="@vm.TotalAmount" currency="d"></money>
                </div>
            </div>
        </div>

        <hr />

        <div class="d-flex flex-wrap gap-2">
            @if (vm.NextStatus.HasValue)
            {
                <form asp-action="AdvanceStatus" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@vm.OrderId" />
                    <button type="submit" class="btn btn-primary btn-sm">
                        Chuyen sang @GetStatusLabel(vm.NextStatus.Value)
                    </button>
                </form>
            }

            @if (vm.CanCancel)
            {
                <form asp-action="CancelOrder" method="post" class="d-inline"
                      onsubmit="return confirm('Ban co chac chan muon huy don hang nay khong?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@vm.OrderId" />
                    <button type="submit" class="btn btn-outline-danger btn-sm">
                        Huy don hang
                    </button>
                </form>
            }

            @if (!vm.NextStatus.HasValue && !vm.CanCancel)
            {
                <span class="text-muted">Don hang da o trang thai cuoi, khong the cap nhat them.</span>
            }
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle bg-white">
        <thead class="table-light">
            <tr>
                <th>Sach</th>
                <th class="text-center">So luong</th>
                <th class="text-end">Don gia</th>
                <th class="text-end">Thanh tien</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in vm.Items)
            {
                <tr>
                    <td>@item.BookTitle</td>
                    <td class="text-center">@item.Quantity</td>
                    <td class="text-end">
                        <money value="@item.UnitPrice" currency="d"></money>
                    </td>
                    <td class="text-end fw-semibold">
                        <money value="@item.LineTotal" currency="d"></money>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
