@model List<Book_Store.Models.Order>

@{
    Layout = "~/Views/Shared/_Admin_Layout.cshtml";
    ViewData["Title"] = "Danh sach don hang";
    var orders = (IReadOnlyList<Book_Store.Models.Order>?)Model ?? Array.Empty<Book_Store.Models.Order>();
}

<h2 class="mb-3">Danh sach don hang</h2>

@if (!orders.Any())
{
    <div class="alert alert-info">Chua co don hang nao.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle bg-white">
            <thead class="table-light">
                <tr>
                    <th>Ma don</th>
                    <th>Khach hang</th>
                    <th>Ngay dat</th>
                    <th>Tong tien</th>
                    <th>Trang thai</th>
                    <th class="text-center">Thao tac</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in orders)
                {
                    <tr>
                        <td>#@order.OrderID</td>
                        <td>@order.CustomerName</td>
                        <td>
                            <date-time value="@order.OrderDate"></date-time>
                        </td>
                        <td>
                            <money value="@order.TotalAmount" currency="d"></money>
                        </td>
                        <td>
                            <order-status-badge status="@order.Status"></order-status-badge>
                        </td>
                        <td>
                            <div class="d-flex flex-wrap gap-2 justify-content-center">
                                <a asp-action="OrderDetails"
                                   asp-route-id="@order.OrderID"
                                   class="btn btn-info btn-sm text-white">
                                    Chi tiet
                                </a>

                                <form asp-action="UpdateStatus" method="post" class="d-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@order.OrderID" />
                                    <select name="status" class="form-select form-select-sm">
                                        @foreach (OrderStatus status in Enum.GetValues(typeof(OrderStatus)))
                                        {
                                            if (status == order.Status)
                                            {
                                                <option value="@status" selected>@status</option>
                                            }
                                            else
                                            {
                                                <option value="@status">@status</option>
                                            }
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-warning btn-sm">Luu</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
