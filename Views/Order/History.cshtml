@model IEnumerable<Book_Store.Models.Order>

@{
    ViewData["Title"] = "Lich su don hang";
    var orders = Model ?? Enumerable.Empty<Book_Store.Models.Order>();
}

<div class="container mt-4 mb-5">
    <h3 class="mb-4">Lich su don hang</h3>

    @if (!orders.Any())
    {
        <div class="alert alert-info">
            Ban chua co don hang nao.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Ma don</th>
                        <th>Ngay dat</th>
                        <th class="text-end">Tong tien</th>
                        <th>Trang thai</th>
                        <th class="text-center">Hanh dong</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in orders)
                    {
                        var statusClass = order.Status switch
                        {
                            Book_Store.Models.OrderStatus.Pending => "bg-secondary",
                            Book_Store.Models.OrderStatus.Confirmed => "bg-info text-dark",
                            Book_Store.Models.OrderStatus.Shipping => "bg-primary",
                            Book_Store.Models.OrderStatus.Completed => "bg-success",
                            Book_Store.Models.OrderStatus.Cancelled => "bg-danger",
                            _ => "bg-secondary"
                        };

                        var statusText = order.Status switch
                        {
                            Book_Store.Models.OrderStatus.Pending => "Cho xac nhan",
                            Book_Store.Models.OrderStatus.Confirmed => "Da xac nhan",
                            Book_Store.Models.OrderStatus.Shipping => "Dang giao",
                            Book_Store.Models.OrderStatus.Completed => "Hoan thanh",
                            Book_Store.Models.OrderStatus.Cancelled => "Da huy",
                            _ => order.Status.ToString()
                        };

                        <tr>
                            <td>#@order.OrderID</td>
                            <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end">@order.TotalAmount.ToString("N0") d</td>
                            <td>
                                <span class="badge @statusClass">@statusText</span>
                            </td>
                            <td class="text-center">
                                <a asp-action="Details"
                                   asp-route-id="@order.OrderID"
                                   class="btn btn-sm btn-outline-primary me-1">
                                    Xem chi tiet
                                </a>

                                <form asp-action="Reorder"
                                      method="post"
                                      class="d-inline">
                                    <input type="hidden" name="id" value="@order.OrderID" />
                                    <button type="submit" class="btn btn-sm btn-warning">
                                        Mua lai
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
