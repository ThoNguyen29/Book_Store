@model IEnumerable<Book_Store.Models.Order>

@{
    ViewData["Title"] = "Lich su don hang";
    var orders = Model ?? Enumerable.Empty<Book_Store.Models.Order>();
}

<div class="container mt-4 mb-5">
    <h3 class="mb-4">Lich su don hang</h3>

    @if (!orders.Any())
    {
        <div class="alert alert-info">
            Ban chua co don hang nao.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Ma don</th>
                        <th>Ngay dat</th>
                        <th class="text-end">Tong tien</th>
                        <th>Trang thai</th>
                        <th class="text-center">Hanh dong</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in orders)
                    {
                        <tr>
                            <td>#@order.OrderID</td>
                            <td>
                                <date-time value="@order.OrderDate"></date-time>
                            </td>
                            <td class="text-end">
                                <money value="@order.TotalAmount" currency="d"></money>
                            </td>
                            <td>
                                <order-status-badge status="@order.Status"></order-status-badge>
                            </td>
                            <td class="text-center">
                                <a asp-action="Details"
                                   asp-route-id="@order.OrderID"
                                   class="btn btn-sm btn-outline-primary me-1">
                                    Xem chi tiet
                                </a>

                                <form asp-action="Reorder" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@order.OrderID" />
                                    <button type="submit" class="btn btn-sm btn-warning">
                                        Mua lai
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
