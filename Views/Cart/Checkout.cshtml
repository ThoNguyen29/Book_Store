@model List<Book_Store.Models.CartItem>

@{
    ViewData["Title"] = "Thanh toán";
    var total = Model.Sum(x => x.Price * x.Quantity);
}

<div class="container mt-5" style="max-width:700px;">
    <h3 class="text-center mb-4">Thanh toán</h3>

    <form asp-action="PlaceOrder" method="post">

        <div class="mb-3">
            <label class="form-label">Địa chỉ giao hàng</label>
            <input type="text" name="address" class="form-control" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Phương thức thanh toán</label>
            <select name="paymentMethod" class="form-select" required>
                <option value="COD">Thanh toán khi nhận hàng</option>
            </select>
        </div>

        <div class="mb-3">
            <strong>Tổng tiền: @total.ToString("N0") đ</strong>
        </div>

        <button type="submit" class="btn btn-success w-100">
            Xác nhận đặt hàng
        </button>
    </form>
    <p>Total: @total</p>
    <form method="POST" asp-action="CreatePaymentMomo" asp-controller="Payment">
        <input type="hidden" name="Amount" value="@total" />
        <input type="hidden" name="OrderInfo" value="Thanh toán đơn hàng" />
        <input type="hidden" name="OrderId" value="@Guid.NewGuid().ToString()" />
        <input type="hidden" name="FullName" value="HAIANSTORE" />
    <button class="btn btn-danger"  type="submit">
        Pay with MoMo
    </button>
</form>
</div>